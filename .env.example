# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=almasur_dashboard
POSTGRES_USER=almasur
POSTGRES_PASSWORD=change_me_strong_password

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://almasur:change_me_strong_password@postgres:5432/almasur_dashboard

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64_char_random_hex

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://dashboardalmasur.jpedesign.cl

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Frontend and API are served from the same origin (Express serves dist/ + /api).
# Leave empty so the frontend calls /api on the same domain.
VITE_API_BASE_URL=
# Set to true to use real API instead of mock data
VITE_USE_REAL_APIS=true

# ── Seed passwords (only needed when running server/seed.js manually) ─────────
SEED_PASSWORD_CARLA=change_me
SEED_PASSWORD_JUAN=change_me
